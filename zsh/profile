# Login-shell PATH shared by ~/.profile (bash/sh) and ~/.zprofile.
# pyenv requires `pyenv init --path` here so shims are on PATH for non-interactive
# shells; interactive hooks stay in oh-my-zsh (plugins=(pyenv)) / ~/.zshrc.

export PYENV_ROOT="${PYENV_ROOT:-$HOME/.pyenv}"
[ -d "$PYENV_ROOT/bin" ] && export PATH="$PYENV_ROOT/bin:$PATH"

if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init --path)"
elif [ -x /opt/homebrew/bin/pyenv ]; then
  eval "$(/opt/homebrew/bin/pyenv init --path)"
elif [ -x /usr/local/bin/pyenv ]; then
  eval "$(/usr/local/bin/pyenv init --path)"
fi
