# .zshenv is always sourced

#
# Homebrew
#

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

#
# Path
#

export PATH=$PATH:/usr/libexec
export PATH=$PATH:/usr/X11/bin
export PATH=/usr/local/sbin:$PATH
export PATH=$HOME/.local/bin:$PATH
export PATH=$HOME/bin:$PATH

#
# Editor
#

export EDITOR="nvim"

#
# Go
#

export GOPATH=$HOME/dev
export PATH=$GOPATH/bin:$PATH
[[ -d /opt/homebrew/opt/go/libexec/bin ]] && export PATH=/opt/homebrew/opt/go/libexec/bin:$PATH

#
# Rust
#

if [[ -r "$HOME/.cargo/env" ]]; then
  source "$HOME/.cargo/env"
fi

#
# Zig
#

export PATH="$HOME/bin/zig:$PATH"

#
# Local overrides (not tracked in git). Put machine-specific config and
# sensitive env vars (API keys, tokens, etc.) in ~/.zshenv.local.
#

[[ -r "$HOME/.zshenv.local" ]] && source "$HOME/.zshenv.local"
